<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>For My Favorite Person 🎀</title>
    <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@500;700&family=Dancing+Script:wght@600&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-cream: #FFFDF5;
            --pastel-pink: #FFD1DC;
            --darker-pink: #FFB7C5;
            --pastel-green: #90C6A9;
            --pastel-red: #EFA8A8;
            --text-red: #B54F4F;
        }

        body {
            background-color: var(--bg-cream);
            font-family: 'Quicksand', sans-serif;
            margin: 0;
            display: flex;
            justify-content: center;
            min-height: 100vh;
            color: #555;
            overflow-x: hidden;
        }

        .container {
            text-align: center;
            width: 95%;
            max-width: 900px;
            padding: 40px 10px;
        }

        .hidden { display: none !important; }

        /* --- SCREEN 1: THE INTERACTIVE QUESTION --- */
        .sticker { width: 180px; margin-bottom: 20px; border-radius: 20px; }
        .btn-container {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 20px;
            min-height: 300px;
        }
        button {
            border: none;
            border-radius: 15px;
            cursor: pointer;
            font-weight: bold;
            transition: all 0.2s ease-out;
        }
        #yesBtn { background-color: var(--pastel-green); color: white; padding: 15px 40px; font-size: 20px; }
        #noBtn { background-color: var(--pastel-red); color: white; padding: 15px 40px; font-size: 20px; }

        /* --- SCREEN 2: GIFT MENU --- */
        .gift-grid {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-top: 30px;
            flex-wrap: wrap;
        }
        .gift-box {
            background-color: var(--pastel-pink);
            border-radius: 20px;
            padding: 25px;
            width: 140px;
            cursor: pointer;
            border: 4px solid #fff;
            transition: 0.3s;
        }
        .gift-box:hover { transform: translateY(-10px); }
        .gift-box img { width: 80px; margin-bottom: 10px; }

        /* --- PAGE 1: 12-PHOTO AESTHETIC GRID --- */
        .photo-strip {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 30px;
            padding: 40px 10px;
        }
        .polaroid {
            background: white;
            padding: 12px 12px 35px 12px;
            box-shadow: 0 8px 20px rgba(0,0,0,0.08);
            position: relative;
            transition: 0.3s;
        }
        .polaroid img { width: 100%; height: 200px; object-fit: cover; border: 1px solid #f0f0f0; }
        .polaroid p { font-family: 'Dancing Script', cursive; margin: 10px 0 0; color: #888; }
        
        /* Messy Rotations */
        .polaroid:nth-child(odd) { transform: rotate(-2deg); }
        .polaroid:nth-child(even) { transform: rotate(2deg); }
        .polaroid:hover { transform: scale(1.05) rotate(0deg); z-index: 5; }

        /* Partner Photo Logic */
        .partner-wrapper {
            grid-column: 1 / -1;
            display: flex;
            justify-content: center;
            gap: 10px;
            padding: 20px 0;
        }
        .partner-left { transform: rotate(-5deg) !important; margin-right: -20px; z-index: 2; }
        .partner-right { transform: rotate(4deg) !important; margin-left: -20px; z-index: 1; }

        /* --- PAGE 2: MUSIC --- */
        .music-card {
            display: flex;
            background: white;
            border-radius: 25px;
            padding: 30px;
            gap: 20px;
            flex-wrap: wrap;
            justify-content: center;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        }
        .vinyl {
            width: 150px; height: 150px;
            background: #222;
            border-radius: 50%;
            border: 10px solid #333;
            animation: spin 6s linear infinite;
            display: flex; align-items: center; justify-content: center;
        }
        @keyframes spin { from {transform: rotate(0deg);} to {transform: rotate(360deg);} }
        .vinyl-inner { width: 50px; height: 50px; background: var(--pastel-pink); border-radius: 50%; border: 3px solid #fff; }

        /* --- PAGE 3: LETTER --- */
        .kiss-bg {
            background-image: url('https://www.transparentpng.com/download/lipstick-stain/lipstick-stain-free-png-2.png'); 
            background-size: 100px;
            background-repeat: repeat;
            padding: 50px 10px;
        }
        .letter-paper {
            background: #fff;
            padding: 50px;
            max-width: 600px;
            margin: 0 auto;
            box-shadow: 5px 10px 30px rgba(0,0,0,0.1);
            transform: rotate(-1deg);
            text-align: left;
            line-height: 1.8;
            font-family: 'Times New Roman', serif;
        }
        .letter-paper h2 { font-family: 'Dancing Script', cursive; color: var(--text-red); }

        .go-back-btn { margin-top: 30px; background: var(--pastel-pink); padding: 12px 30px; color: white; border-radius: 10px; }
    </style>
</head>
<body>

<div class="container">
    <div id="screen1">
        <img src="https://media.tenor.com/978mshzG3_0AAAAi/myaowl-cute.gif" class="sticker">
        <h1 id="mainTitle" style="color: var(--text-red)">Do you love me? 🎀</h1>
        <div class="btn-container">
            <button id="yesBtn" onclick="showGifts()">Yes</button>
            <button id="noBtn" onclick="handleNo()">No</button>
        </div>
    </div>

    <div id="screen2" class="hidden">
        <h1 style="color: var(--text-red); font-family: 'Dancing Script', cursive; font-size: 2.5rem;">I knew you'd say yes hehe 💞</h1>
        <img src="https://media.tenor.com/S8WfF1v_m84AAAAi/myaowl-cat.gif" class="sticker">
        <div class="gift-grid">
            <div class="gift-box" onclick="showPage('page1')"><img src="https://cdn-icons-png.flaticon.com/512/2143/2143150.png"><p>MEMORIES</p></div>
            <div class="gift-box" onclick="showPage('page2')"><img src="https://cdn-icons-png.flaticon.com/512/2143/2143150.png"><p>OUR SONG</p></div>
            <div class="gift-box" onclick="showPage('page3')"><img src="https://cdn-icons-png.flaticon.com/512/2143/2143150.png"><p>MY LETTER</p></div>
        </div>
    </div>

    <div id="page1" class="hidden">
        <h1 style="color: var(--text-red)">Captured Memories</h1>
        <div class="photo-strip">
            <div class="polaroid"><img src="20260217015836_1.jpg"><p>moment one</p></div>
            <div class="polaroid"><img src="20260328095546_1.jpg"><p>precious</p></div>
            <div class="polaroid"><img src="20260328100013_1.jpg"><p>stolen shots</p></div>
            <div class="polaroid"><img src="20260328101557_1.jpg"><p>captured</p></div>
            <div class="polaroid"><img src="20260228215635_1.jpg"><p>always</p></div>
            <div class="polaroid"><img src="SKY_20260403_092922.jpg"><p>skies with you</p></div>

            <div class="partner-wrapper">
                <div class="polaroid partner-left"><img src="2325290_1925.jpg"><p>partner</p></div>
                <div class="polaroid partner-right"><img src="SKY_20260403_085117.jpg"><p>photos</p></div>
            </div>

            <div class="polaroid"><img src="SKY_20260226_201203.jpg"><p>starry nights</p></div>
            <div class="polaroid"><img src="20260304134815_1.jpg"><p>love</p></div>
            <div class="polaroid"><img src="SKY_20260323_224725.jpg"><p>our world</p></div>
            <div class="polaroid"><img src="SKY_20260324_081529.jpg"><p>forever</p></div>
        </div>
        <button class="go-back-btn" onclick="showGifts()">Go back</button>
    </div>

    <div id="page2" class="hidden">
        <h1 style="color: var(--text-red)">A song that reminds me of us</h1>
        <div class="music-card">
            <div class="vinyl"><div class="vinyl-inner"></div></div>
            <div style="flex:1; min-width:300px; aspect-ratio:16/9;">
                <iframe width="100%" height="100%" src="https://www.youtube.com/embed/NsC7WGV-xU4" frameborder="0" allowfullscreen></iframe>
            </div>
        </div>
        <button class="go-back-btn" onclick="showGifts()">Go back</button>
    </div>

    <div id="page3" class="hidden">
        <div class="kiss-bg">
            <div class="letter-paper">
                <h2>Happy Valentine's Day, My Love</h2>
                <p>Today is Valentine's Day, and I just want you to know how grateful I am to have you in my life. You make every ordinary moment feel special.</p>
                <p>Being with you feels like home. I find comfort in you, and I will never take your love for granted.</p>
                <p style="text-align: right; font-family: 'Dancing Script', cursive; font-size: 1.5rem; color: var(--text-red);">Forever yours,</p>
            </div>
        </div>
        <button class="go-back-btn" onclick="showGifts()">Go back</button>
    </div>
</div>

<script>
    let clicks = 0;
    const phrases = ["Wait... are you sure? qwq", "Nah that's not right...", "Try again please T-T", "Be serious.", "Okay now you're teasing me :vvv", "Okay last chance."];
    function handleNo() {
        clicks++;
        const noBtn = document.getElementById('noBtn');
        const yesBtn = document.getElementById('yesBtn');
        const title = document.getElementById('mainTitle');
        if (clicks <= 6) {
            title.innerText = phrases[clicks - 1];
            yesBtn.style.transform = `scale(${1 + clicks * 0.5})`;
            noBtn.style.transform = `scale(${1 - clicks * 0.15})`;
            if (clicks === 6) noBtn.style.display = 'none';
        }
    }
    function showGifts() {
        document.querySelectorAll('.container > div').forEach(div => div.classList.add('hidden'));
        document.getElementById('screen2').classList.remove('hidden');
    }
    function showPage(id) {
        document.getElementById('screen2').classList.add('hidden');
        document.getElementById(id).classList.remove('hidden');
        window.scrollTo(0,0);
    }
</script>
</body>
</html>
